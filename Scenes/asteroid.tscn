[gd_scene format=3 uid="uid://it307ruobgy5"]

[sub_resource type="PhysicsMaterial" id="PhysicsMaterial_t0yec"]
bounce = 1.0

[sub_resource type="GDScript" id="GDScript_yfktk"]
script/source = "@tool
extends RigidBody2D

@export var radius : = 32 :
	set(new_radius):
		radius = new_radius
		update_shape()
@export var resolution : = 360:
	set(new_res):
		resolution = new_res
		update_shape()
#Line width pixel size
#@export var line_width : = 10 :
#Line width proportional
@export_range(0.0, 1.0) var line_width : = 0.05 :
	set(new_lw):
		line_width = new_lw
		update_shape()
@export var variance_range : int = 16:
	set(new_v_range):
		variance_range = new_v_range
		update_shape()
@export var noise : FastNoiseLite:
	set(new_noise):
		noise = new_noise
		noise.changed.connect(update_shape)


@onready var polygon_2d: Polygon2D = $Polygon2D
@onready var line_2d: Line2D = $Line2D
@onready var collision_polygon_2d: CollisionPolygon2D = $CollisionPolygon2D


func _ready() -> void:
	noise = noise.duplicate()

func set_radius(new_radius : int):
	radius = new_radius

	update_shape()

func update_shape():
	if not is_node_ready():
		await ready
	if Engine.is_editor_hint():
		collision_polygon_2d = $CollisionPolygon2D
		polygon_2d = $Polygon2D
		line_2d = $Line2D

	collision_polygon_2d.polygon.clear()
	polygon_2d.polygon.clear()
	line_2d.clear_points()
	var circle_points : = []
	for i in range(resolution):
		var vec : = Vector2.RIGHT
		vec *= radius
		vec += Vector2.RIGHT * noise.get_noise_1d(i) * variance_range
		vec = vec.rotated(i * (TAU / resolution))
		circle_points.append(vec)
	line_2d.points = circle_points
	polygon_2d.polygon = circle_points
	collision_polygon_2d.polygon = circle_points
	#Line width pixel size
	#line_2d.width = line_width
	#Line width proportional
	line_2d.width = line_width * radius
"

